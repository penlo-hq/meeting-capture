{
  "manifest_version": 3,
  "name": "Penlo Meeting Capture",
  "version": "1.0.0",
  "description": "Capture Google Meet and Zoom captions into Penlo Enterprise Brain",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "http://localhost:8000/*",
    "https://*.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Penlo Meeting Capture"
  }
}
